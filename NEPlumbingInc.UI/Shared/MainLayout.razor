@inherits LayoutComponentBase

<PageTitle>NEPlumbingInc.UI</PageTitle>

<style>
    :root {
        --navbar-height: 64px;
    }

    .page {
        position: relative;
        display: flex;
        flex-direction: column;
        padding-top: var(--navbar-height);  /* Add padding to account for fixed navbar */
    }

    main {
        flex: 1;
        /* Remove margin-top since we're using padding on .page */
    }

    .content {
        padding-top: 2rem;  /* Increased padding for better spacing */
    }

    .page {
        position: relative;
        display: flex;
        flex-direction: column;
    }

    main {
        margin-top: var(--navbar-height);
        flex: 1;
    }

    .content {
        padding-top: 1.1rem;
    }

    :deep .container-fluid {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    :deep .nav-links {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-grow: 1;
        gap: 1rem;
    }

    :deep .auth-links {
        margin-left: auto;
    }
</style>

<div class="page">
    <NavMenu />
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>