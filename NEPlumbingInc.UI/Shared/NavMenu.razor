@inject AuthenticationStateProvider AuthStateProvider

<style>
    .navbar-dark {
        background-color: #770000 !important;
        padding: 0.5rem 1rem;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
    }

    .container-fluid {
        display: flex;
        align-items: center;
        min-height: 64px;
    }

    .nav-links {
        display: flex;
        align-items: stretch;
        /* Changed from center */
        gap: 1rem;
        margin: 0 auto;
    }

    .nav-item {
        display: flex;
        align-items: center;
        margin: 0;
    }

    .nav-link {
        display: inline-flex;
        /* Changed from flex */
        align-items: center;
        justify-content: center;
        color: #ffffff !important;
        transition: all 0.3s ease;
        padding: 0.5rem 1rem;
        white-space: nowrap;
        line-height: 1.5;
        /* Added for consistent text height */
    }

    .nav-link span {
        margin-right: 0.5rem;
        display: inline-flex;
        /* Added */
        align-items: center;
        /* Added */
    }

    .nav-link:hover {
        background-color: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
    }

    .nav-link.active {
        background-color: rgba(255, 255, 255, 0.2);
        border-radius: 4px;
    }

    .navbar-brand {
        color: #ffffff !important;
        font-weight: 600;
        letter-spacing: 0.5px;
        font-size: 1.25rem;
        margin-right: 2rem;
    }

    .auth-links {
        display: flex;
        gap: 1rem;
        margin-left: auto;
    }
</style>

<nav class="navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">NE Plumbing Inc</a>

        <div class="nav-links">
            <div class="nav-item">
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                    <span class="oi oi-home" aria-hidden="true"></span> Home
                </NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="services">
                    <span class="oi oi-plus" aria-hidden="true"></span> Services
                </NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="projects">
                    <span class="oi oi-image" aria-hidden="true"></span> Our Work
                </NavLink>
            </div>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="auth-links">
                    <div class="nav-item">
                        <NavLink class="nav-link" href="admin-dashboard">
                            <span class="oi oi-dashboard" aria-hidden="true"></span> Admin
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="admin-logout">
                            <span class="oi oi-account-logout" aria-hidden="true"></span> Logout
                        </NavLink>
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="auth-links">
                    <div class="nav-item">
                        <NavLink class="nav-link" href="admin-login">
                            <span class="oi oi-account-login" aria-hidden="true"></span> Login
                        </NavLink>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}